<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Viewer" Height="560" Width="900"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Refresh" Click="OnRefresh" />
                <Button Content="Open Folder" Click="OnOpenFolder" />
                <Button Content="Close" IsCancel="True" />
            </StackPanel>
            <TextBlock x:Name="PathText" VerticalAlignment="Center" Foreground="#666" TextTrimming="CharacterEllipsis" />
        </DockPanel>
        <TextBox x:Name="LogText" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Background="#FAFAFA" />
    </DockPanel>
</Window>
