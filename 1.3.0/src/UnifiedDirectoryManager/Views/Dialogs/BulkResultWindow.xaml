<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.BulkResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk operation results" Height="480" Width="680"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="Summary" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,8" />
        <ListView x:Name="Items" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Object" Width="200" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Result" Width="90" DisplayMemberBinding="{Binding Outcome}" />
                    <GridViewColumn Header="Detail" Width="340" DisplayMemberBinding="{Binding Detail}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button Grid.Row="2" Content="Close" IsDefault="True" IsCancel="True" HorizontalAlignment="Right"
                MinWidth="90" Margin="0,12,0,0" />
    </Grid>
</Window>
