<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.EntraSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entra Connect — Delta Sync" Height="480" Width="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,10"
                   Text="Runs 'Start-ADSyncSyncCycle -PolicyType Delta' on the Entra Connect (Azure AD Connect) server via PowerShell remoting (WinRM)." />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Server" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Hostname or FQDN of the Entra Connect server" />
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <RadioButton GroupName="SyncCred" IsChecked="{Binding UseSavedAccount}"
                         Visibility="{Binding HasSavedAccount, Converter={StaticResource BoolToVis}}"
                         Content="{Binding SavedAccountName, StringFormat='Use saved sync account ({0})'}"
                         ToolTip="The account saved in Settings ▸ Entra Connect for this server." />
            <RadioButton GroupName="SyncCred" Content="Use my current logged-in user" IsChecked="{Binding UseCurrentUser}" Margin="0,4,0,0" />
            <RadioButton GroupName="SyncCred" Content="Specify credentials" IsChecked="{Binding UseSpecificCredentials}" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,6,0,0" IsEnabled="{Binding UseSpecificCredentials}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="DOMAIN\user or user@domain" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
            <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" Margin="0,2" Padding="3,2" />
        </Grid>

        <TextBox Grid.Row="4" Text="{Binding Output, Mode=OneWay}" IsReadOnly="True" Margin="0,12,0,0"
                 FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Background="#FAFAFA" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Run Delta Sync" IsDefault="True" Command="{Binding RunCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" MinWidth="120" />
            <Button Content="Close" IsCancel="True" Click="OnClose" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
