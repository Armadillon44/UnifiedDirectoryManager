<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Unified Directory Manager" Height="320" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="Unified Directory Manager" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Active Directory and Entra management tool" Foreground="#666" Margin="0,2,0,0" />
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock x:Name="VersionText" Margin="0,2" />
            <TextBlock x:Name="RuntimeText" Margin="0,2" />
            <TextBlock Text="Developer: LaCrosse Footwear, Inc." Margin="0,2" />
            <TextBlock Text="Author: D Dreier" Margin="0,2" />
            <TextBlock Text="Logs:" Margin="0,8,0,0" Foreground="#666" />
            <TextBlock x:Name="LogPathText" TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Row="2" Content="Close" IsDefault="True" IsCancel="True" HorizontalAlignment="Right" MinWidth="90" />
    </Grid>
</Window>
