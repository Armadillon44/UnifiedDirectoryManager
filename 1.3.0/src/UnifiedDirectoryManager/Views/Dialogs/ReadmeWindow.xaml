<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.ReadmeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unified Directory Manager — README" Height="680" Width="820"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <Button DockPanel.Dock="Bottom" Content="Close" IsCancel="True" Click="OnClose" HorizontalAlignment="Right"
                MinWidth="90" Margin="0,8,0,0" />
        <TextBox x:Name="ReadmeText" IsReadOnly="True" FontFamily="Consolas" FontSize="12.5"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 BorderThickness="0" Background="#FCFCFC" Padding="6" />
    </DockPanel>
</Window>
