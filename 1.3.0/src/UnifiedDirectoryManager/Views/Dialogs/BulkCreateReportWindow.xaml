<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.BulkCreateReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Create — Results" Height="600" Width="1060"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Summary}" FontWeight="SemiBold" FontSize="14" />
        <TextBlock Grid.Row="1" Margin="0,4,0,8" TextWrapping="Wrap" Foreground="#B8860B"
                   Text="Passwords and Temporary Access Passes are shown only here and are NOT written to the log. Copy or export them now; the export CSV contains the plaintext passwords." />

        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="User" Width="150" Binding="{Binding Label}" />
                <DataGridTextColumn Header="Logon name" Width="110" Binding="{Binding SamAccountName}" />
                <DataGridTextColumn Header="Result" Width="60" Binding="{Binding ResultText}" />

                <DataGridTemplateColumn Header="Password" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Copy" Padding="6,0" Click="OnCopyPassword"
                                        Visibility="{Binding GeneratedPassword, Converter={StaticResource NonEmptyToVis}}" />
                                <TextBox Text="{Binding GeneratedPassword, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" />
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Temporary Access Pass" Width="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Copy" Padding="6,0" Click="OnCopyTap"
                                        Visibility="{Binding TapCode, Converter={StaticResource NonEmptyToVis}}" />
                                <TextBox Text="{Binding TapCode, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" />
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Cloud result" Width="190" Binding="{Binding CloudSummary}" />
                <DataGridTextColumn Header="Error" Width="*" Binding="{Binding Error}" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Export CSV…" Click="OnExport" MinWidth="100" />
            <Button Content="Close" IsCancel="True" IsDefault="True" Click="OnClose" Margin="8,0,0,0" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
