<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.CloudLicensePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign licenses" Height="460" Width="620"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="#666" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="Select the license(s) to assign directly (Ctrl/Shift-click for several). Where a SKU is already assigned via a group, prefer adding the user to that group instead — you'll be asked to confirm before any direct assignment." />

        <ListView Grid.Row="1" x:Name="SkuList" ItemsSource="{Binding Skus}"
                  SelectionMode="Extended" VirtualizingStackPanel.IsVirtualizing="False">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Product" Width="240" DisplayMemberBinding="{Binding FriendlyName}" />
                    <GridViewColumn Header="SKU" Width="160" DisplayMemberBinding="{Binding SkuPartNumber}" />
                    <GridViewColumn Header="Availability" Width="180" DisplayMemberBinding="{Binding AvailabilityText}" />
                </GridView>
            </ListView.View>
        </ListView>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#666" VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" IsDefault="True" Click="OnOk" MinWidth="90" Margin="0,0,6,0" />
                <Button Content="Cancel" IsCancel="True" MinWidth="90" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
