<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.MultiValueEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit values" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="Heading" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,8" />

        <ListBox x:Name="ValuesList" Grid.Row="1" />

        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Add" Click="OnAdd" Margin="6,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Remove" Click="OnRemove" />
            <TextBox x:Name="NewValue">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{x:Null}" />
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Click="OnOk" MinWidth="90" />
            <Button Content="Cancel" IsCancel="True" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
