<Window x:Class="UnifiedDirectoryManager.Views.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UnifiedDirectoryManager.Views.Controls"
        Title="Connect to Active Directory" Height="520" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Connect to a domain" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentText}" />
            <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,2,0,10"
                       Text="Enter the domain and a domain controller (hostname or IP). Discovery is best-effort — on Entra-only clients, type a DC manually." />
        </StackPanel>

        <controls:ConnectionFormView Grid.Row="1" VerticalAlignment="Top" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Connect" IsDefault="True" Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" MinWidth="90" />
            <Button Content="Cancel" IsCancel="True" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
