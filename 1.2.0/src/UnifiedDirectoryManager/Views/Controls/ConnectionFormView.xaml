<UserControl x:Class="UnifiedDirectoryManager.Views.Controls.ConnectionFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Domain (FQDN)" Style="{StaticResource FieldLabel}" />
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DomainFqdn, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Primary DC (host/IP)" Style="{StaticResource FieldLabel}" />
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox IsEditable="True" Text="{Binding PrimaryDc, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding DiscoveredDcs}" />
                <Button Grid.Column="1" Content="Discover" Command="{Binding DiscoverCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Margin="6,0,0,0" />
            </Grid>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Fall-back DCs" Style="{StaticResource FieldLabel}" />
            <TextBox   Grid.Row="2" Grid.Column="1" Height="54" AcceptsReturn="True" TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Text="{Binding FallbackDcsText, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="One host or IP per line (or comma-separated). Tried in order after the primary." />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabel}" />
            <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="DOMAIN\user or user@domain" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Password" Style="{StaticResource FieldLabel}" />
            <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox" Margin="0,2" Padding="3,2" />

            <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Content="Use LDAPS (port 636)"
                      IsChecked="{Binding UseLdaps}" />
            <CheckBox Grid.Row="5" Grid.Column="1" Margin="160,8,0,0" Content="Ignore cert errors (insecure)"
                      IsChecked="{Binding IgnoreCertificateErrors}" IsEnabled="{Binding UseLdaps}"
                      ToolTip="Only enable if the DC's LDAPS certificate isn't trusted/doesn't match — bypasses MITM protection." />
            <CheckBox Grid.Row="6" Grid.Column="1" Margin="0,6,0,0"
                      Content="Save credentials in Windows Credential Manager"
                      IsChecked="{Binding SaveCredentials}" />
        </Grid>

        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="#444" Margin="0,12,0,0" />
    </StackPanel>
</UserControl>
