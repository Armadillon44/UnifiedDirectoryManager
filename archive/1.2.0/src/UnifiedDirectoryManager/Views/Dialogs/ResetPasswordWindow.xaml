<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password" Height="380" Width="460"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10">
            <Run Text="Set a new password for " />
            <Run Text="{Binding AccountTitle, Mode=OneWay}" FontWeight="SemiBold" />
            <Run Text="." />
        </TextBlock>

        <TextBlock Grid.Row="1" Text="New password" Style="{StaticResource FieldLabel}" />
        <DockPanel Grid.Row="2">
            <Button DockPanel.Dock="Right" Content="Generate" Command="{Binding GeneratePasswordCommand}" Margin="6,2,0,2" />
            <PasswordBox x:Name="PasswordBox" Margin="0,2" Padding="3,2" />
        </DockPanel>

        <TextBlock Grid.Row="3" Text="Confirm password" Style="{StaticResource FieldLabel}" Margin="0,6,0,0" />
        <PasswordBox Grid.Row="4" x:Name="ConfirmBox" Margin="0,2" Padding="3,2" />

        <DockPanel Grid.Row="5" Margin="0,4,0,0" Visibility="{Binding GeneratedPassword, Converter={StaticResource NonEmptyToVis}}">
            <Button DockPanel.Dock="Right" Content="Copy" Click="OnCopyPassword" Margin="6,0,0,0" />
            <TextBox Text="{Binding GeneratedPassword, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"
                     Foreground="#0A7" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                     ToolTip="Select to copy, or use the Copy button" />
        </DockPanel>

        <CheckBox Grid.Row="6" Content="User must change password at next logon"
                  IsChecked="{Binding MustChangeAtNextLogon}" Margin="0,12,0,0" />
        <CheckBox Grid.Row="7" Content="Unlock the account" IsChecked="{Binding Unlock}" Margin="0,6,0,0" />

        <TextBlock Grid.Row="8" Text="{Binding Error}" Foreground="#B00020" TextWrapping="Wrap"
                   VerticalAlignment="Bottom" Margin="0,10,0,0" />

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Reset" IsDefault="True" Click="OnOk" MinWidth="90" />
            <Button Content="Cancel" IsCancel="True" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
