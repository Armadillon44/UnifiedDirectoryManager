<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.OuPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Properties" Height="380" Width="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Center" />
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,0,8" VerticalAlignment="Center" TextWrapping="Wrap" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Distinguished name" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DistinguishedName, Mode=OneWay}" IsReadOnly="True"
                 TextWrapping="Wrap" Background="#F7F7F7" Margin="0,0,0,8"
                 ToolTip="LDAP distinguished name (copyable)" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Canonical name" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Center" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CanonicalName, Mode=OneWay}" IsReadOnly="True"
                 TextWrapping="Wrap" Background="#F7F7F7" Margin="0,0,0,8"
                 ToolTip="Canonical name, e.g. corp.example.com/Sales (copyable)" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Description" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Top" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding CanEdit}" TextWrapping="Wrap" AcceptsReturn="False" MinLines="2" MaxHeight="80"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                 ToolTip="Edit the OU description, then click Save." />

        <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,4,0,10" />

        <CheckBox Grid.Row="5" Grid.ColumnSpan="2" Content="Protect object from accidental deletion"
                  IsChecked="{Binding ProtectFromDeletion}" IsEnabled="{Binding CanEdit}"
                  ToolTip="Adds/removes an Everyone:Deny Delete/DeleteTree ACE (the same protection ADUC's checkbox sets)." />

        <DockPanel Grid.Row="7" Grid.ColumnSpan="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#666" VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsLoaded}" MinWidth="90" />
                <Button Content="Close" IsCancel="True" MinWidth="90" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
