<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.ScenarioEditorWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Action Scenarios" Height="660" Width="900"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Scenario list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Scenarios" FontWeight="SemiBold" Margin="0,0,0,4" />
            <WrapPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                <Button Content="New" Command="{Binding NewScenarioCommand}" />
                <Button Content="Clone" Command="{Binding CloneCommand}" />
                <Button Content="Delete" Command="{Binding DeleteCommand}" />
                <Button Content="Import…" Command="{Binding ImportCommand}" />
                <Button Content="Export…" Command="{Binding ExportCommand}" />
            </WrapPanel>
            <ListBox ItemsSource="{Binding Scenarios}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedScenario}" />
        </DockPanel>

        <!-- Editor -->
        <DockPanel Grid.Column="1">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Scenario name" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                <DockPanel Margin="0,12,0,4">
                    <Button DockPanel.Dock="Right" Content="Add step" Command="{Binding AddStepCommand}" />
                    <TextBlock Text="Steps (run top to bottom, for each selected object)" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>
            </StackPanel>

            <!-- Action buttons + status -->
            <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <TextBlock Text="{Binding ScenariosDirectory}" Foreground="#999" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save" Command="{Binding SaveCommand}" MinWidth="90" />
                    <Button Content="Close" IsCancel="True" Click="OnClose" MinWidth="90" />
                </StackPanel>
            </DockPanel>
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="#666" Margin="0,8,0,0" />

            <!-- Steps -->
            <Border BorderBrush="#DDD" BorderThickness="1" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="3" Margin="0,3" Padding="6"
                                        Background="#FAFAFA">
                                    <StackPanel>
                                        <!-- Action + reorder/remove -->
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="↑" Width="28" MinWidth="28" ToolTip="Move up"
                                                        Command="{Binding DataContext.MoveStepUpCommand, ElementName=Root}" CommandParameter="{Binding}" />
                                                <Button Content="↓" Width="28" MinWidth="28" ToolTip="Move down"
                                                        Command="{Binding DataContext.MoveStepDownCommand, ElementName=Root}" CommandParameter="{Binding}" />
                                                <Button Content="✕" Width="28" MinWidth="28" ToolTip="Remove step"
                                                        Command="{Binding DataContext.RemoveStepCommand, ElementName=Root}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                            <ComboBox ItemsSource="{Binding AllActions}" SelectedItem="{Binding Action}" MinWidth="220"
                                                      HorizontalAlignment="Left">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ScenarioActionLabel}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DockPanel>

                                        <!-- Attribute (Set/Clear attribute) -->
                                        <DockPanel Margin="0,6,0,0" Visibility="{Binding ShowAttribute, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Attribute:" VerticalAlignment="Center" Margin="0,0,6,0" Width="64" />
                                            <ComboBox ItemsSource="{Binding Attributes}" DisplayMemberPath="Friendly"
                                                      SelectedValuePath="LdapName" SelectedValue="{Binding Attribute}" />
                                        </DockPanel>

                                        <!-- Value (Set attribute / Set description) -->
                                        <StackPanel Margin="0,6,0,0" Visibility="{Binding ShowValue, Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <TextBlock Text="Value:" VerticalAlignment="Center" Margin="0,0,6,0" Width="64" />
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <TextBlock Text="Tokens: {date} {datetime} {time} {admin} {name}" Foreground="#999" FontSize="11" Margin="70,2,0,0" />
                                        </StackPanel>

                                        <!-- Groups (Add/Remove from groups) -->
                                        <DockPanel Margin="0,6,0,0" Visibility="{Binding ShowGroups, Converter={StaticResource BoolToVis}}">
                                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="6,0,0,0">
                                                <Button Content="Pick groups…" Command="{Binding PickGroupsCommand}" Margin="0,0,0,4" />
                                                <Button Content="Remove" Command="{Binding RemoveGroupCommand}"
                                                        CommandParameter="{Binding SelectedItem, ElementName=StepGroups}" />
                                            </StackPanel>
                                            <ListBox x:Name="StepGroups" ItemsSource="{Binding Groups}" DisplayMemberPath="Name" Height="72" />
                                        </DockPanel>

                                        <!-- Cloud groups (Cloud add/remove from groups) -->
                                        <DockPanel Margin="0,6,0,0" Visibility="{Binding ShowCloudGroups, Converter={StaticResource BoolToVis}}">
                                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="6,0,0,0">
                                                <Button Content="Pick groups…" Command="{Binding PickCloudGroupsCommand}" Margin="0,0,0,4" />
                                                <Button Content="Remove" Command="{Binding RemoveCloudGroupCommand}"
                                                        CommandParameter="{Binding SelectedItem, ElementName=StepCloudGroups}" />
                                            </StackPanel>
                                            <ListBox x:Name="StepCloudGroups" ItemsSource="{Binding CloudGroups}" DisplayMemberPath="Name" Height="72" />
                                        </DockPanel>

                                        <!-- OU (Move to OU) -->
                                        <DockPanel Margin="0,6,0,0" Visibility="{Binding ShowOu, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Target OU:" VerticalAlignment="Center" Margin="0,0,6,0" Width="64" />
                                            <Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseOuCommand}" Margin="6,0,0,0" />
                                            <TextBox Text="{Binding TargetOu, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>

                                        <!-- Forwarding target (Exchange: set mailbox forwarding) -->
                                        <StackPanel Margin="0,6,0,0" Visibility="{Binding ShowForwarding, Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <TextBlock Text="Forward to:" VerticalAlignment="Center" Margin="0,0,6,0" Width="64" />
                                                <Button DockPanel.Dock="Right" Content="Pick…" Command="{Binding PickForwardingTargetCommand}" Margin="6,0,0,0" />
                                                <TextBlock Text="{Binding ForwardingTargetDisplay}" VerticalAlignment="Center" Foreground="#444" TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                            <CheckBox Content="Also deliver a copy to the mailbox" IsChecked="{Binding DeliverAndForward}" Margin="70,4,0,0" />
                                        </StackPanel>

                                        <!-- Save operation log (meta-step) -->
                                        <TextBlock Margin="0,6,0,0" Foreground="#666" FontSize="11" TextWrapping="Wrap"
                                                   Visibility="{Binding ShowLogNote, Converter={StaticResource BoolToVis}}"
                                                   Text="Writes a plain-text log of every step taken and change made in this run (e.g. the groups removed). The folder is set in Settings ▸ Logs; you'll be reminded of the path and can change it when the scenario runs. Position doesn't matter — one log is written per run." />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</Window>
