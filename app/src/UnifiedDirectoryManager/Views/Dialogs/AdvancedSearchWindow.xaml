<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.AdvancedSearchWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Search" Height="680" Width="720"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Saved searches: load / save / delete / share the current query -->
        <Border Grid.Row="0" Background="#F2F6FB" BorderBrush="#DCE6F2" BorderThickness="1" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <WrapPanel>
                    <TextBlock Text="Saved search:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="240" ItemsSource="{Binding SavedSearches}" DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedSavedSearch}" Margin="0,0,6,4"
                              ToolTip="{Binding SelectedSavedSearch.Description}" />
                    <Button Content="Load" Command="{Binding LoadSearchCommand}" Margin="0,0,4,4" MinWidth="56" />
                    <Button Content="Delete" Command="{Binding DeleteSearchCommand}" Margin="0,0,12,4" MinWidth="56" />
                    <Button Content="Export…" Command="{Binding ExportSearchCommand}" Margin="0,0,4,4" />
                    <Button Content="Import…" Command="{Binding ImportSearchCommand}" Margin="0,0,0,4" />
                </WrapPanel>
                <WrapPanel Margin="0,2,0,0">
                    <TextBlock Text="Save current as:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="240" Text="{Binding SaveName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0">
                        <TextBox.InputBindings>
                            <!-- Enter here saves the search; without this it would trigger the default Search button and close the dialog. -->
                            <KeyBinding Key="Enter" Command="{Binding SaveSearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Save" Command="{Binding SaveSearchCommand}" MinWidth="56" />
                    <TextBlock Text="{Binding SavedStatus}" Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Type + match mode -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Width="220" ItemsSource="{Binding ObjectTypeOptions}" DisplayMemberPath="Label"
                      SelectedValuePath="Value" SelectedValue="{Binding ObjectType}" Margin="0,0,16,0" />
            <RadioButton Content="Match ALL conditions" GroupName="m" IsChecked="{Binding MatchAll}" VerticalAlignment="Center" Margin="0,0,12,0" />
            <RadioButton Content="Match ANY condition" GroupName="m" VerticalAlignment="Center"
                         IsChecked="{Binding MatchAll, Converter={StaticResource InverseBool}}" />
        </WrapPanel>

        <!-- Scope -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Width="300" ItemsSource="{Binding ScopeOptions}" DisplayMemberPath="Label"
                      SelectedValuePath="Value" SelectedValue="{Binding Scope}" />
        </WrapPanel>

        <!-- Search bases (OUs) -->
        <DockPanel Grid.Row="3" Margin="0,0,0,8" LastChildFill="True">
            <TextBlock DockPanel.Dock="Left" Text="Search in:" VerticalAlignment="Top" Margin="0,4,6,0" />
            <Button DockPanel.Dock="Right" Content="Add OU…" VerticalAlignment="Top" Margin="6,2,0,0"
                    Command="{Binding BrowseBasesCommand}" />
            <StackPanel>
                <Border BorderBrush="#DDD" BorderThickness="1" MinHeight="46" MaxHeight="104">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchBases}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Display}" ToolTip="{Binding Dn}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="1" Content="✕" Width="24" MinWidth="24" Padding="0"
                                                Command="{Binding DataContext.RemoveBaseCommand, ElementName=Root}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <TextBlock Text="Leave empty to search the whole domain." Foreground="#999" Margin="0,2,0,0" FontSize="11" />
            </StackPanel>
        </DockPanel>

        <!-- Conditions -->
        <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="1" Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Conditions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,4,0"
                                          ItemsSource="{Binding DataContext.Attributes, ElementName=Root}"
                                          DisplayMemberPath="Friendly" SelectedValuePath="LdapName"
                                          SelectedValue="{Binding LdapName}" />
                                <ComboBox Grid.Column="1" Margin="0,0,4,0"
                                          ItemsSource="{Binding DataContext.Operators, ElementName=Root}"
                                          SelectedItem="{Binding Operator}" />
                                <TextBox Grid.Column="2" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="3" Content="✕" Width="28" MinWidth="28" Margin="4,0,0,0"
                                        Command="{Binding DataContext.RemoveConditionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="5" Content="Add condition" HorizontalAlignment="Left" Margin="0,8,0,0"
                Command="{Binding AddConditionCommand}" />

        <!-- Raw filter + preview -->
        <StackPanel Grid.Row="6" Margin="0,8,0,0">
            <CheckBox Content="Use raw LDAP filter (advanced)" IsChecked="{Binding UseRawFilter}" />
            <TextBox Text="{Binding RawFilter, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding UseRawFilter}" Margin="0,4,0,0"
                     ToolTip="e.g. (department=Sales)" />
            <TextBlock Text="Effective filter:" Foreground="#666" Margin="0,8,0,0" />
            <TextBox Text="{Binding PreviewFilter, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                     Background="#F7F7F7" />
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Search" IsDefault="True" Click="OnSearch" MinWidth="90" />
            <Button Content="Cancel" IsCancel="True" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
