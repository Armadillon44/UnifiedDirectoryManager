<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.TemplateEditorWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Creation Templates" Height="640" Width="820"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Template list -->
        <DockPanel Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top" Text="Templates" FontWeight="SemiBold" Margin="0,0,0,4" />
            <WrapPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                <Button Content="New" Command="{Binding NewTemplateCommand}" />
                <Button Content="Clone" Command="{Binding CloneCommand}" />
                <Button Content="Delete" Command="{Binding DeleteCommand}" />
                <Button Content="Import…" Command="{Binding ImportCommand}" />
                <Button Content="Export…" Command="{Binding ExportCommand}" />
            </WrapPanel>
            <ListBox ItemsSource="{Binding Templates}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedTemplate}" />
        </DockPanel>

        <!-- Editor -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Template name" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Target OU" Style="{StaticResource FieldLabel}" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Browse…" Command="{Binding BrowseOuCommand}" Margin="6,2,0,2" />
                    <TextBox Text="{Binding TargetOu, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>
                <TextBlock Text="UPN suffix (for {upnSuffix} token)" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding UpnSuffix, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. lacrossefootwear.com or danner.com" />
                <TextBlock Text="Email (mail) — tokens allowed" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="e.g. {sam}@lacrossefootwear.com" />
                <TextBlock Text="User logon name (UPN) — tokens allowed" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Upn, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Syncs to Entra. e.g. {sam}@lacrossefootwear.com or {sam}@{upnSuffix}" />
                <TextBlock Text="Proxy addresses (one per line, tokens allowed)" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding ProxyAddressesText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="NoWrap" Height="56" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         ToolTip="SMTP: (uppercase) = primary. e.g. SMTP:{sam}@lacrossefootwear.com / smtp:{sam}@danner.com" />
                <TextBlock Text="Country/region" Style="{StaticResource FieldLabel}" />
                <ComboBox ItemsSource="{Binding Countries}" DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedCountry}" IsEditable="True" IsTextSearchEnabled="True"
                          MaxDropDownHeight="320"
                          ToolTip="Sets co (name), c (two-letter code) and countryCode (numeric) for new users." />

                <TextBlock Text="Manager (default for new users)" Style="{StaticResource FieldLabel}" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Clear" Command="{Binding ClearManagerCommand}" Margin="6,2,0,2" />
                    <Button DockPanel.Dock="Right" Content="Pick…" Command="{Binding PickManagerCommand}" Margin="6,2,0,2" />
                    <TextBox Text="{Binding ManagerDisplay, Mode=OneWay}" IsReadOnly="True" />
                </DockPanel>

                <CheckBox Content="Account enabled by default" IsChecked="{Binding EnabledByDefault}" Margin="0,8,0,0" />
                <CheckBox Content="Must change password at next logon" IsChecked="{Binding MustChangePassword}" Margin="0,4,0,0" />

                <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,12,0,4"
                           Text="Attribute defaults — tokens: {first} {last} {middle} {firstInitial} {lastInitial} {middleInitial} {initials} {sam} {upnSuffix}" />
                <ItemsControl ItemsSource="{Binding AttributeRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,4,0" ItemsSource="{Binding Attributes}"
                                          DisplayMemberPath="Friendly" SelectedValuePath="LdapName"
                                          SelectedValue="{Binding LdapName}" />
                                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2" Content="✕" Width="28" MinWidth="28" Margin="4,0,0,0"
                                        Command="{Binding DataContext.RemoveAttributeCommand, ElementName=Root}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Add attribute" HorizontalAlignment="Left" Margin="0,6,0,0"
                        Command="{Binding AddAttributeCommand}" />

                <TextBlock Text="Groups" FontWeight="SemiBold" Margin="0,12,0,4" />
                <TextBlock TextWrapping="Wrap" Foreground="#999" FontSize="11" Margin="0,0,0,4"
                           Text="One list for every kind of group: on-prem AD, Entra ID (cloud), and Exchange Online distribution groups. Cloud and Exchange groups are added after creation, so selecting any makes a post-create Entra Connect sync mandatory in the New User wizard (it waits for the user to sync, then adds them)." />
                <ListBox x:Name="GroupsList" ItemsSource="{Binding Groups}" MaxHeight="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Name, Mode=OneWay}" /><Run Text="  ·  " Foreground="#999" /><Run Text="{Binding ChannelLabel, Mode=OneWay}" Foreground="#999" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <WrapPanel Margin="0,6,0,0">
                    <Button Content="Add groups…" Command="{Binding PickGroupsCommand}" />
                    <Button Content="Remove selected" Command="{Binding RemoveGroupCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=GroupsList}" />
                </WrapPanel>

                <DockPanel Margin="0,16,0,0">
                    <TextBlock Text="{Binding Status}" Foreground="#666" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Save" Command="{Binding SaveCommand}" MinWidth="90" />
                        <Button Content="Close" IsCancel="True" Click="OnClose" MinWidth="90" />
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding TemplatesDirectory}" Foreground="#999" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
