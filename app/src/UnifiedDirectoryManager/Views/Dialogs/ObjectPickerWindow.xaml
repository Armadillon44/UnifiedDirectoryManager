<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.ObjectPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select objects" Height="520" Width="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Heading}" Foreground="#666" Margin="0,0,0,8" />

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Search" Command="{Binding SearchCommand}" Margin="6,0,0,0" />
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" x:Name="AddCol" />
                <ColumnDefinition Width="220" x:Name="BasketCol" />
            </Grid.ColumnDefinitions>

            <!-- IsVirtualizing=False works around a WPF bug where dynamically-populated list rows
                 don't paint until the mouse hovers over them. Result sets are capped at 200 rows. -->
            <ListView Grid.Column="0" x:Name="ResultsList" ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedResult}" SelectionMode="Extended"
                      VirtualizingStackPanel.IsVirtualizing="False"
                      MouseDoubleClick="OnResultDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="180" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Logon" Width="120" DisplayMemberBinding="{Binding [sAMAccountName]}" />
                        <GridViewColumn Header="Description" Width="140" DisplayMemberBinding="{Binding [description]}" />
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- The basket/Add UI is only shown for multi-select pickers; a single-select picker
                 (e.g. Manager) commits the highlighted row directly. Collapsed in code-behind. -->
            <StackPanel Grid.Column="1" x:Name="AddPanel" VerticalAlignment="Center" Margin="6,0">
                <Button Content="Add →" Command="{Binding AddToBasketCommand}"
                        CommandParameter="{Binding SelectedItems, ElementName=ResultsList}" Margin="0,0,0,6" />
                <TextBlock Text="Ctrl/Shift-click to select several" Foreground="#999" FontSize="10"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="74" />
            </StackPanel>

            <DockPanel Grid.Column="2" x:Name="BasketPanel">
                <TextBlock DockPanel.Dock="Top" Text="Selected" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ListBox x:Name="Basket" ItemsSource="{Binding Basket}" DisplayMemberPath="Name"
                         VirtualizingStackPanel.IsVirtualizing="False"
                         MouseDoubleClick="OnBasketDoubleClick" />
            </DockPanel>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#666" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" IsDefault="True" Click="OnOk" MinWidth="90" />
                <Button Content="Cancel" IsCancel="True" MinWidth="90" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
