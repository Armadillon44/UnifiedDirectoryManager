<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.CopyGroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy Groups to User" Height="560" Width="640"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,8"
                       Text="Copy this user's group memberships onto another user. Untick any you don't want to copy, choose the target user, then Copy. The target's existing memberships are left as-is (this only adds)." />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="From" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourceDisplay, Mode=OneWay}" IsReadOnly="True"
                         Background="#F3F3F3" Foreground="#666" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="To" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,4,0,0" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetDisplay, Mode=OneWay}" IsReadOnly="True" Margin="0,4,0,0" />
                <Button Grid.Row="1" Grid.Column="2" Content="Pick user…" Command="{Binding PickTargetCommand}" Margin="6,4,0,0" />
            </Grid>
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,12,0,4">
            <TextBlock Text="Groups to copy" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
            <Button Content="Select all" Command="{Binding SelectAllCommand}" />
            <Button Content="Select none" Command="{Binding SelectNoneCommand}" Margin="6,0,0,0" />
        </WrapPanel>

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Include}" Margin="0,1">
                                <CheckBox.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock Text="{Binding Detail}" Foreground="#999" Margin="8,0,0,0" />
                                    </StackPanel>
                                </CheckBox.Content>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Margin="0,10,0,0" MaxHeight="140" BorderBrush="#DDD" BorderThickness="1"
                Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ProgressSteps}" Margin="6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" Margin="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding Status}" Foreground="#666" Margin="0,10,0,0" TextWrapping="Wrap" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy" IsDefault="True" Command="{Binding CopyCommand}" MinWidth="90" Margin="0,0,6,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
            <Button Content="Close" IsCancel="True" Click="OnClose" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
