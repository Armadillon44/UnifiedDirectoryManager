<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.NewOuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Organizational Unit" Height="300" Width="560"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Create in" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ParentDn, Mode=OneWay}" IsReadOnly="True"
                 Background="#F7F7F7" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Center" />
        <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" Margin="0,0,0,8">
            <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding CreateCommand}" />
            </TextBox.InputBindings>
        </TextBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description" Foreground="#666" Margin="0,0,10,8" VerticalAlignment="Top" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" TextWrapping="Wrap"
                 AcceptsReturn="False" MinLines="2" MaxHeight="70" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" />

        <CheckBox Grid.Row="3" Grid.Column="1" Content="Protect object from accidental deletion"
                  IsChecked="{Binding ProtectFromDeletion}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                  Margin="0,2,0,0" />

        <DockPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding Status}" Foreground="#666" VerticalAlignment="Center" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create" IsDefault="True" Command="{Binding CreateCommand}" MinWidth="90" />
                <Button Content="Cancel" IsCancel="True" MinWidth="90" Margin="8,0,0,0" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
