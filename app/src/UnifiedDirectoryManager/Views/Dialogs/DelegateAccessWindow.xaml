<Window x:Class="UnifiedDirectoryManager.Views.Dialogs.DelegateAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change delegate access" SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">
    <StackPanel Margin="14">
        <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,10"
                   Text="{Binding DelegateName, StringFormat='Set the mailbox access for {0}:'}" />

        <CheckBox Content="Full Access (open / read / manage the mailbox)" IsChecked="{Binding FullAccess}" Margin="0,0,0,6" />
        <CheckBox Content="Send As (send as the mailbox)" IsChecked="{Binding SendAs}" Margin="0,0,0,6" />
        <CheckBox Content="Send on Behalf (send on behalf of the mailbox)" IsChecked="{Binding SendOnBehalf}" Margin="0,0,0,10" />
        <CheckBox Content="Auto-map in Outlook (applies when Full Access is newly granted)" IsChecked="{Binding AutoMapping}" Margin="0,0,0,4" />

        <TextBlock Foreground="#999" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                   Text="Unticking a permission the delegate currently has will remove it." />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" IsDefault="True" Click="OnOk" MinWidth="90" Margin="0,0,6,0" />
            <Button Content="Cancel" IsCancel="True" MinWidth="90" />
        </StackPanel>
    </StackPanel>
</Window>
