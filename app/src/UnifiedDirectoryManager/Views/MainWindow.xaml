<Window x:Class="UnifiedDirectoryManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UnifiedDirectoryManager.ViewModels"
        xmlns:ctrl="clr-namespace:UnifiedDirectoryManager.Views.Controls"
        Title="Unified Directory Manager" Height="760" Width="1240" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New User…" Command="{Binding NewUserCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <MenuItem Header="_Bulk Create Users…" Command="{Binding BulkCreateUsersCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <MenuItem Header="_Open Selected…" Command="{Binding OpenSelectedCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" />
                <Separator Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <MenuItem Header="_Export List to CSV…" Command="{Binding ExportCsvCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Separator />
                <MenuItem Header="_View Log File…" Command="{Binding ViewLogCommand}" />
                <MenuItem Header="Open Logs _Folder" Command="{Binding OpenLogsCommand}" />
                <Separator />
                <MenuItem Header="_Settings…" Command="{Binding OpenSettingsCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit" IsEnabled="{Binding IsAdView}">
                <MenuItem Header="_Advanced Search…" Command="{Binding AdvancedSearchCommand}" />
                <MenuItem Header="Cop_y User…" Command="{Binding CopyUserCommand}" />
                <MenuItem Header="Copy _Groups to User…" Command="{Binding CopyGroupsToUserCommand}" />
                <MenuItem Header="Add Selected to _Groups…" Command="{Binding AddSelectedToGroupsCommand}" />
                <MenuItem Header="_Bulk Edit…" Command="{Binding BulkEditCommand}" />
                <Separator />
                <MenuItem Header="_Delete Selected…" Command="{Binding DeleteSelectedCommand}" />
                <Separator />
                <MenuItem Header="User Creation _Templates…" Command="{Binding ManageTemplatesCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle Pane _Dock (Right / Bottom)" Command="{Binding ToggleDockCommand}" />
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Entra Connect Delta Sync…" Command="{Binding EntraSyncCommand}" />
                <Separator />
                <MenuItem Header="Run _Scenario on Selected" ItemsSource="{Binding ScenarioMenuItems}" IsEnabled="{Binding HasScenarios}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Name}" />
                            <Setter Property="Command" Value="{Binding RunCommand}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="_Manage Scenarios…" Command="{Binding ManageScenariosCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="View _README…" Command="{Binding ViewReadmeCommand}" />
                <Separator />
                <MenuItem Header="_View Log File…" Command="{Binding ViewLogCommand}" />
                <MenuItem Header="Open Logs _Folder" Command="{Binding OpenLogsCommand}" />
                <Separator />
                <MenuItem Header="_About Unified Directory Manager…" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar. On-prem-specific actions hide in the cloud view (IsAdView); the cloud list has its
             own toolbar for search/filter/columns/export. Refresh, Dock and Logs apply to both views. -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <ToolBar.Resources>
                    <!-- Keep the App.xaml Button template (BasedOn) but give toolbar buttons breathing room. -->
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Margin" Value="3,1" />
                        <Setter Property="Padding" Value="9,3" />
                    </Style>
                </ToolBar.Resources>
                <Button Content="New User…" Command="{Binding NewUserCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Bulk Create…" Command="{Binding BulkCreateUsersCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Templates…" Command="{Binding ManageTemplatesCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Separator Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Advanced Search…" Command="{Binding AdvancedSearchCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Add to Groups…" Command="{Binding AddSelectedToGroupsCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Bulk Edit…" Command="{Binding BulkEditCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Separator Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Content="Export CSV…" Command="{Binding ExportCsvCommand}" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}" />
                <Separator />
                <Button Content="Logs" Command="{Binding OpenLogsCommand}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Not-connected warning bar (yellow). Shown when on-prem AD isn't bound; the app stays usable
             (cloud management) and the user can connect from here. Hidden once AdWarning is cleared. -->
        <Border DockPanel.Dock="Top" Background="#FFF4CE" BorderBrush="#E0C36A" BorderThickness="0,0,0,1" Padding="10,6"
                Visibility="{Binding AdWarning, Converter={StaticResource NonEmptyToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Connect…" Command="{Binding OpenSettingsCommand}" Margin="10,0,0,0" />
                <TextBlock Text="⚠" Foreground="#B8860B" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding AdWarning}" Foreground="#5C4700" VerticalAlignment="Center" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!-- Status bar. The right-hand item tracks the active view (on-prem list vs cloud list). -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource AccentLight}">
            <StatusBarItem><TextBlock Text="{Binding ConnectedInfo}" /></StatusBarItem>
            <Separator />
            <StatusBarItem><TextBlock Text="{Binding StatusMessage}" /></StatusBarItem>
            <Separator />
            <StatusBarItem Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding List.Status}" />
            </StatusBarItem>
            <StatusBarItem Visibility="{Binding IsCloudView, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding Cloud.Status}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content -->
        <Grid x:Name="RootGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation tree -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBar}">
                    <TextBlock Text="Directory" Style="{StaticResource HeaderBarText}" />
                </Border>
                <TreeView x:Name="Tree" ItemsSource="{Binding RootNodes}"
                          SelectedItemChanged="OnTreeSelectedItemChanged" BorderThickness="0,1,0,0"
                          AllowDrop="True" DragOver="OnTreeDragOver" Drop="OnTreeDrop"
                          ToolTip="Drag objects from the list onto an OU here to move them.">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Glyph}" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- On-prem AD: list + edit pane host (re-laid out by code-behind for right/bottom docking).
                 Shown when an on-prem tree node is selected. -->
            <Grid x:Name="PaneHost" Grid.Column="2" Visibility="{Binding IsAdView, Converter={StaticResource BoolToVis}}">
                <Border x:Name="ListHost">
                    <ctrl:ObjectListView DataContext="{Binding List}" />
                </Border>
                <GridSplitter x:Name="PaneSplitter" Background="#DDD" />
                <Border x:Name="EditHost" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                    <ctrl:EditPaneView DataContext="{Binding Edit}" />
                </Border>
            </Grid>

            <!-- Entra ID (cloud) list + read-only properties pane (laid out by code-behind, same Right/Bottom
                 dock toggle as the on-prem pane). Shown when a cloud tree node is selected. -->
            <Grid x:Name="CloudPaneHost" Grid.Column="2" Visibility="{Binding IsCloudView, Converter={StaticResource BoolToVis}}">
                <Border x:Name="CloudListHost">
                    <ctrl:CloudObjectListView DataContext="{Binding Cloud}" />
                </Border>
                <GridSplitter x:Name="CloudPaneSplitter" Background="#DDD" />
                <Border x:Name="CloudDetailHost" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                    <ctrl:CloudDetailView DataContext="{Binding Cloud.Detail}" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
