{
  // Pin C# Dev Kit to the active solution (app/) so it loads exactly those
  // projects instead of globbing every *.csproj in the workspace. Globbing is
  // what transiently picks up the WPF markup-compile temp project
  // (UnifiedDirectoryManager_xxxx_wpftmp.csproj), which is created and deleted
  // during a build and causes "project file cannot be found" errors.
  // The frozen 1.2.0 reference build lives under archive/1.2.0/.
  "dotnet.defaultSolution": "app/UnifiedDirectoryManager.sln",

  // Don't watch build output (reduces churn and spurious project-reload noise).
  "files.watcherExclude": {
    "**/bin/**": true,
    "**/obj/**": true
  }
}
